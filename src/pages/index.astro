---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ForgeCF — AI consulting that ships production systems, not strategy decks." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>ForgeCF — We build AI systems that work.</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#0a0f1e] text-slate-100 font-sans antialiased">

  <!-- ── NAV ─────────────────────────────────────────────────────────────── -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#0a0f1e]/90 backdrop-blur-md">
    <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
      <span class="text-white font-bold text-xl tracking-tight">ForgeCF</span>
      <div class="hidden md:flex items-center gap-8 text-sm text-slate-400">
        <a href="#products" class="hover:text-white transition-colors">Products</a>
        <a href="#approach" class="hover:text-white transition-colors">Approach</a>
        <a href="#engagements" class="hover:text-white transition-colors">Engagements</a>
        <a href="#contact" class="hover:text-white transition-colors">Contact</a>
      </div>
      <a href="#contact"
         class="rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-500 transition-colors">
        Talk to us
      </a>
    </div>
  </nav>

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
    <!-- Animated grid background -->
    <div class="animated-grid absolute inset-0 opacity-60"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(59,130,246,0.15),transparent)]"></div>

    <div class="relative mx-auto max-w-7xl px-6 py-32 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 mb-8 text-xs font-medium text-blue-400 uppercase tracking-widest">
        Production AI Systems
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white leading-[1.05] mb-6">
        We build AI systems<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">that work.</span>
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Not strategy decks. Not POCs. Production systems that pass the 2&nbsp;AM test.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#products"
           class="rounded-md bg-blue-600 px-8 py-3.5 text-sm font-semibold text-white hover:bg-blue-500 transition-colors shadow-lg shadow-blue-600/20">
          See what we build
        </a>
        <a href="#contact"
           class="rounded-md border border-white/10 bg-white/5 px-8 py-3.5 text-sm font-semibold text-slate-300 hover:bg-white/10 hover:text-white transition-colors">
          Talk to us
        </a>
      </div>
    </div>
  </section>

  <!-- ── THE PROBLEM ──────────────────────────────────────────────────────── -->
  <section id="problem" class="py-28 bg-[#0f1628]">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">The Reality</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white">The execution gap is real.</h2>
      </div>

      <!-- Stat cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 text-center">
          <div class="text-6xl font-black text-blue-400 mb-3">88%</div>
          <div class="text-slate-300 font-medium mb-2">of AI pilots never reach production</div>
          <div class="text-xs text-slate-500">MIT NANDA Research</div>
        </div>
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 text-center">
          <div class="text-6xl font-black text-indigo-400 mb-3">95%</div>
          <div class="text-slate-300 font-medium mb-2">of GenAI pilots deliver zero measurable return</div>
          <div class="text-xs text-slate-500">Industry Analysis 2024</div>
        </div>
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 text-center">
          <div class="text-6xl font-black text-blue-400 mb-3">$200B</div>
          <div class="text-slate-300 font-medium mb-2">enterprise AI spend by 2028</div>
          <div class="text-xs text-slate-500">mostly wasted on strategy</div>
        </div>
      </div>

      <!-- Pull quotes -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <blockquote class="rounded-xl border-l-4 border-red-500/50 bg-red-950/20 px-8 py-6">
          <p class="text-slate-300 italic text-lg leading-relaxed mb-4">
            "Our AI transformation roadmap is comprehensive and positions us well for the future."
          </p>
          <footer class="text-sm text-slate-500">— Big 4 AI Transformation Report, delivered 18 months and $4M later. Zero systems in production.</footer>
        </blockquote>
        <blockquote class="rounded-xl border-l-4 border-red-500/50 bg-red-950/20 px-8 py-6">
          <p class="text-slate-300 italic text-lg leading-relaxed mb-4">
            "We've completed the discovery phase and are ready to move into strategy definition."
          </p>
          <footer class="text-sm text-slate-500">— Enterprise AI Assessment, month 6 of 8. Still no code written. Client moved on.</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ── HOW WE'RE DIFFERENT ───────────────────────────────────────────────── -->
  <section id="approach" class="py-28">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Approach</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white">How we're different.</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 hover:border-blue-500/30 transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center mb-6 group-hover:bg-blue-500/20 transition-colors">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">We ship systems</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Every engagement ends with working software in production. 4–12 week timelines. Not roadmaps.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 hover:border-blue-500/30 transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-indigo-500/10 flex items-center justify-center mb-6 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Governance is architecture</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            RBAC, guardrails, and audit logging baked in from day 1. Not bolted on after the fact.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 hover:border-blue-500/30 transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center mb-6 group-hover:bg-blue-500/20 transition-colors">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Vendor-neutral</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            We recommend what fits your situation. Hardware partnerships, but recommendations are driven by your requirements.
          </p>
        </div>

        <!-- Card 4 -->
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 hover:border-blue-500/30 transition-colors group">
          <div class="w-12 h-12 rounded-lg bg-indigo-500/10 flex items-center justify-center mb-6 group-hover:bg-indigo-500/20 transition-colors">
            <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-3">Full-service</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Hardware procurement through managed operations. Or just the architecture and handoff. Your call.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PLATFORM ECOSYSTEM ────────────────────────────────────────────────── -->
  <section id="products" class="py-28 bg-[#0f1628] dot-bg">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Products</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white">Our platform ecosystem.</h2>
        <p class="text-slate-400 mt-4 max-w-xl mx-auto">Four interconnected products built from real consulting engagements.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Lake -->
        <div class="rounded-xl border border-white/5 bg-[#111827]/80 backdrop-blur p-8 hover:border-blue-500/30 transition-colors">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Lake</h3>
              <p class="text-xs text-blue-400">Enterprise Data Foundation</p>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            Iceberg-based DataLake with hybrid search — keyword, semantic, and freshness scoring in a single query.
          </p>
          <ul class="space-y-2 text-sm text-slate-500">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>Connectors: SharePoint, Salesforce, Email, Teams, file drop</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>Tenant-isolated, GDPR-ready, governance baked in</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>Powers KIRT and any downstream intelligence layer</li>
          </ul>
        </div>

        <!-- KIRT -->
        <div class="rounded-xl border border-white/5 bg-[#111827]/80 backdrop-blur p-8 hover:border-indigo-500/30 transition-colors">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">KIRT</h3>
              <p class="text-xs text-indigo-400">Knowledge In Real Time</p>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            AI-powered account intelligence layer with LangGraph multi-agent pipelines for research, prep, and insights.
          </p>
          <ul class="space-y-2 text-sm text-slate-500">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>Research reports, engagement prep, meeting summaries</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>Cross-sell recommendations via pgvector similarity</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>Branded deliverables exported to SharePoint</li>
          </ul>
        </div>

        <!-- Forge SDLC -->
        <div class="rounded-xl border border-white/5 bg-[#111827]/80 backdrop-blur p-8 hover:border-blue-500/30 transition-colors">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Forge SDLC</h3>
              <p class="text-xs text-blue-400">AI-Powered Development</p>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            8-agent SDLC pipeline that composes PreFlight research, GSD execution, and ECC quality gates.
          </p>
          <ul class="space-y-2 text-sm text-slate-500">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>Agents: Research, Dev, Testing, Security, Ops, UX, Memory, Manager</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>Greenfield and brownfield AI development</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>Semi-automated: Manager recommends, you approve</li>
          </ul>
        </div>

        <!-- Enterprise AI Framework -->
        <div class="rounded-xl border border-white/5 bg-[#111827]/80 backdrop-blur p-8 hover:border-indigo-500/30 transition-colors">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">Enterprise AI Framework</h3>
              <p class="text-xs text-indigo-400">Consulting Methodology</p>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">
            6-phase lifecycle: Discover → Educate → Advise → Propose → Build → Operationalize.
          </p>
          <ul class="space-y-2 text-sm text-slate-500">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>Maturity assessment (6 dimensions), intake questionnaire</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>Engagement tiers from $100K starter to enterprise managed ops</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 flex-shrink-0"></span>Compliance: NIST AI RMF, EU AI Act, SOC 2, HIPAA</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ENGAGEMENT TIERS ──────────────────────────────────────────────────── -->
  <section id="engagements" class="py-28">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Pricing</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white">Engagements.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Starter -->
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-lg font-bold text-white mb-1">Starter</h3>
            <div class="text-3xl font-black text-slate-100 mb-1">~$100K</div>
            <div class="text-sm text-slate-500">services + hardware</div>
          </div>
          <ul class="space-y-3 text-sm text-slate-400 flex-1 mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              4–8 weeks to production
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              One use case live in production
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Gateway + RAG + governance + monitoring
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Small GPU server, 8–13B models
            </li>
          </ul>
          <a href="#contact" class="rounded-md border border-blue-500/30 bg-blue-500/10 px-6 py-3 text-sm font-semibold text-blue-400 text-center hover:bg-blue-500/20 transition-colors">
            Get started
          </a>
        </div>

        <!-- Standard — highlighted -->
        <div class="rounded-xl border border-blue-500/50 bg-[#111827] p-8 flex flex-col relative ring-1 ring-blue-500/30">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="rounded-full bg-blue-600 px-4 py-1 text-xs font-semibold text-white">Most popular</span>
          </div>
          <div class="mb-6">
            <h3 class="text-lg font-bold text-white mb-1">Standard</h3>
            <div class="text-3xl font-black text-slate-100 mb-1">$200–500K</div>
            <div class="text-sm text-slate-500">services + hardware</div>
          </div>
          <ul class="space-y-3 text-sm text-slate-400 flex-1 mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              8–12 weeks to production
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              3–5 use cases, compliance mapping
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Multi-tier inference (8B + 70B models)
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Full RBAC, audit trail, red-team testing
            </li>
          </ul>
          <a href="#contact" class="rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white text-center hover:bg-blue-500 transition-colors">
            Get started
          </a>
        </div>

        <!-- Enterprise -->
        <div class="rounded-xl border border-white/5 bg-[#111827] p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-lg font-bold text-white mb-1">Enterprise</h3>
            <div class="text-3xl font-black text-slate-100 mb-1">Custom</div>
            <div class="text-sm text-slate-500">long-term partnership</div>
          </div>
          <ul class="space-y-3 text-sm text-slate-400 flex-1 mb-8">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-indigo-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Managed operations
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-indigo-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Fractional AI CTO
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-indigo-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Hardware procurement (Dell, HPE, IBM, NVIDIA)
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-indigo-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Long-term partnership
            </li>
          </ul>
          <a href="#contact" class="rounded-md border border-indigo-500/30 bg-indigo-500/10 px-6 py-3 text-sm font-semibold text-indigo-400 text-center hover:bg-indigo-500/20 transition-colors">
            Let's talk
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ───────────────────────────────────────────────────────────── -->
  <section id="contact" class="py-28 bg-[#0f1628]">
    <div class="mx-auto max-w-3xl px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Contact</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white">Ready to stop piloting<br />and start producing?</h2>
        <p class="text-slate-400 mt-4">Drop us a line. We'll respond within one business day.</p>
      </div>

      <form
        name="contact"
        method="POST"
        action="mailto:contact@forgecf.com"
        class="rounded-xl border border-white/5 bg-[#111827] p-8 space-y-5"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2" for="name">Name</label>
            <input
              id="name" name="name" type="text" required
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2" for="company">Company</label>
            <input
              id="company" name="company" type="text"
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition"
              placeholder="Acme Corp"
            />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2" for="email">Email</label>
          <input
            id="email" name="email" type="email" required
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition"
            placeholder="jane@acme.com"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2" for="message">Message</label>
          <textarea
            id="message" name="message" rows="5" required
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition resize-none"
            placeholder="Tell us about your AI initiative and where you're stuck..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-blue-600 px-6 py-3.5 text-sm font-semibold text-white hover:bg-blue-500 transition-colors shadow-lg shadow-blue-600/20"
        >
          Send message
        </button>
        <p class="text-center text-xs text-slate-500">
          Or email us directly at <a href="mailto:contact@forgecf.com" class="text-blue-400 hover:underline">contact@forgecf.com</a>
        </p>
      </form>
    </div>
  </section>

