                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-white">Manufacturing</h3>
              <p class="text-xs text-slate-500">Industrial, Defense & Critical Infrastructure</p>
            </div>
          </div>
          <p class="text-sm text-slate-400 mb-4">Operational AI for the shop floor — quality, safety, and supply chain with export controls baked in.</p>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full border border-blue-500/20 bg-blue-500/5 px-2.5 py-1 text-xs text-blue-400">ISO 9001</span>
            <span class="rounded-full border border-blue-500/20 bg-blue-500/5 px-2.5 py-1 text-xs text-blue-400">ISO 27001</span>
            <span class="rounded-full border border-blue-500/20 bg-blue-500/5 px-2.5 py-1 text-xs text-blue-400">ITAR/EAR</span>
            <span class="rounded-full border border-blue-500/20 bg-blue-500/5 px-2.5 py-1 text-xs text-blue-400">IEC 62443</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PARTNER CHANNEL ───────────────────────────────────────────────────── -->
  <section id="partners" class="py-16 bg-[#0f1628]">
    <div class="mx-auto max-w-5xl px-6">
      <div class="rounded-xl border border-white/5 bg-[#111827] p-8 md:p-10">
        <div class="text-center mb-8">
          <p class="text-sm font-semibold text-slate-500 uppercase tracking-widest mb-3">Partner Channel</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-white">We extend what your platform vendor delivers.</h2>
          <p class="text-slate-400 mt-3 max-w-2xl mx-auto text-sm">Your hardware and platform vendor delivers the substrate. We build the governance, observability, and use cases on top.</p>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
          <div class="text-center">
            <div class="text-slate-300 font-semibold text-sm mb-1">Red Hat OpenShift AI</div>
            <div class="text-xs text-slate-500">Platform substrate</div>
          </div>
          <div class="text-slate-600 hidden md:block">·</div>
          <div class="text-center">
            <div class="text-slate-300 font-semibold text-sm mb-1">Dell AI Factory</div>
            <div class="text-xs text-slate-500">Infrastructure layer</div>
          </div>
          <div class="text-slate-600 hidden md:block">·</div>
          <div class="text-center">
            <div class="text-slate-300 font-semibold text-sm mb-1">IBM watsonx</div>
            <div class="text-xs text-slate-500">Enterprise AI platform</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ───────────────────────────────────────────────────────────── -->
  <section id="contact" class="py-28 bg-[#0f1628]">
    <div class="mx-auto max-w-3xl px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-blue-400 uppercase tracking-widest mb-3">Contact</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-white">Not sure where to start?</h2>
        <p class="text-slate-400 mt-4 max-w-lg mx-auto">Start with a workshop and walk out knowing exactly what to build. Or just talk to us about your situation.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
          <a href="#contact-form"
             class="rounded-md bg-blue-600 px-8 py-3.5 text-sm font-semibold text-white hover:bg-blue-500 transition-colors shadow-lg shadow-blue-600/20">
            Start with a workshop
          </a>
          <a href="mailto:contact@forgecf.com"
             class="rounded-md border border-white/10 bg-white/5 px-8 py-3.5 text-sm font-semibold text-slate-300 hover:bg-white/10 hover:text-white transition-colors">
            Talk to us about your situation
          </a>
        </div>
      </div>

      <form
        id="contact-form"
        name="contact"
        method="POST"
        action="mailto:contact@forgecf.com"
        class="rounded-xl border border-white/5 bg-[#111827] p-8 space-y-5"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2" for="name">Name</label>
            <input
              id="name" name="name" type="text" required
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2" for="company">Company</label>
            <input
              id="company" name="company" type="text"
              class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition"
              placeholder="Acme Corp"
            />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2" for="email">Email</label>
          <input
            id="email" name="email" type="email" required
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition"
            placeholder="jane@acme.com"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-2" for="message">Message</label>
          <textarea
            id="message" name="message" rows="5" required
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 transition resize-none"
            placeholder="Tell us about your AI initiative and where you're stuck..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-blue-600 px-6 py-3.5 text-sm font-semibold text-white hover:bg-blue-500 transition-colors shadow-lg shadow-blue-600/20"
        >
          Send message
        </button>
        <p class="text-center text-xs text-slate-500">
          Or email us directly at <a href="mailto:contact@forgecf.com" class="text-blue-400 hover:underline">contact@forgecf.com</a>
        </p>
      </form>
    </div>
  </section>

